# Configuration reelle du deploiement Passbolt
# Adapter les valeurs avant execution de deploy.sh

PASSBOLT_DOMAIN=passbolt.example.com
STACK_DIR=/opt/docker-compose/passbolt

# TLS local (laisser vide si reverse proxy)
TLS_CERT_PATH=
TLS_KEY_PATH=

# SMTP (recommande)
SMTP_FROM_NAME=Passbolt
SMTP_FROM_ADDRESS=passbolt@example.com
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=user@example.com
SMTP_PASSWORD=ChangeMe
SMTP_TLS=tls
