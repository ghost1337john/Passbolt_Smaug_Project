# Copier ce fichier en passbolt.env puis adapter les valeurs

# Obligatoire
PASSBOLT_DOMAIN=passbolt.example.com

# Optionnel
STACK_DIR=/opt/docker-compose/passbolt

# TLS local (laisser vide si reverse proxy)
TLS_CERT_PATH=
TLS_KEY_PATH=

# SMTP (si renseigne, le script injecte automatiquement ces valeurs dans le compose)
SMTP_FROM_NAME=Passbolt
SMTP_FROM_ADDRESS=passbolt@example.com
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=user@example.com
SMTP_PASSWORD=ChangeMe
SMTP_TLS=tls
